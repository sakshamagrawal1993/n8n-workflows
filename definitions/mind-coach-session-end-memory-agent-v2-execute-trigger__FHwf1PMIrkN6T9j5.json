        "schemaType": "manual",
        "inputSchema": "{\n  \"type\": \"object\",\n  \"properties\": {\n    \"extracted_memories\": {\n      \"type\": \"array\",\n      \"minItems\": 1,\n      \"maxItems\": 3,\n      \"items\": {\n        \"anyOf\": [\n          {\n            \"type\": \"object\",\n            \"properties\": {\n              \"memory_text\": { \"type\": \"string\" },\n              \"memory_type\": {\n                \"type\": \"string\",\n                \"enum\": [\"life_context\"],\n                \"default\": \"life_context\"\n              }\n            },\n            \"required\": [\"memory_text\"],\n            \"additionalProperties\": true\n          },\n          {\n            \"type\": \"string\"\n          }\n        ]\n      }\n    },\n    \"output\": {\n      \"type\": \"object\",\n      \"properties\": {\n        \"extracted_memories\": {\n          \"type\": \"array\",\n          \"minItems\": 1,\n          \"maxItems\": 3,\n          \"items\": {\n            \"anyOf\": [\n              {\n                \"type\": \"object\",\n                \"properties\": {\n                  \"memory_text\": { \"type\": \"string\" },\n                  \"memory_type\": {\n                    \"type\": \"string\",\n                    \"enum\": [\"life_context\"],\n                    \"default\": \"life_context\"\n                  }\n                },\n                \"required\": [\"memory_text\"],\n                \"additionalProperties\": true\n              },\n              { \"type\": \"string\" }\n            ]\n          }\n        }\n      },\n      \"additionalProperties\": true\n    }\n  },\n  \"anyOf\": [\n    { \"required\": [\"extracted_memories\"] },\n    { \"required\": [\"output\"] }\n  ],\n  \"additionalProperties\": true\n}",
        "autoFix": false
