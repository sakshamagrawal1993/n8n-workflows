    {
      "parameters": {
        "jsCode": "const d = $json || {};\nconst profile = d.profile || {};\nconst session = d.session || {};\nconst currentMemory = d.current_memory?.memory_text || d.current_memory?.text || 'None recorded';\nconst systemPrompt = [\n  'You are a clinical memory synthesizer for an AI therapist.',\n  'Generate exactly one updated consolidated long-term memory block for the patient.',\n  'Preserve durable facts that you receive from the current consolidated memory and integrate meaningful updates from this session data to form a complete picture of the patient from a mental health point of view',\n  'Return ONLY valid JSON.'\n].join('\\n');\nconst userPrompt = [\n  'CLIENT CONTEXT:', JSON.stringify({ name: profile.name || 'User', concerns: profile.concerns || [], pathway: session.pathway || '' }),\n  '', 'CURRENT CONSOLIDATED MEMORY:', String(currentMemory),\n  '', 'RECENT CASE NOTES:', JSON.stringify(d.recent_case_notes || []),\n  '', 'MESSAGES:', JSON.stringify(d.messages || []),\n  '', 'TRANSCRIPT:', d.transcript || '',\n  '', 'Return JSON schema: {\"extracted_memories\":[{\"memory_text\":\"string\",\"memory_type\":\"life_context\"}]}'\n].join('\\n');\nreturn [{ json: { systemPrompt, userPrompt } }];"
      },
      "id": "e97163c8-23d7-4b6c-b330-98b26261e877",
      "name": "Prompt Builder",
      "type": "n8n-nodes-base.code",
