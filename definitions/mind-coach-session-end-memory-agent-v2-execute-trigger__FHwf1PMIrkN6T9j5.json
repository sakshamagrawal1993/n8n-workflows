      ],
      "id": "1bee5f12-b7a2-4e54-8060-840fdaf8abfb",
      "name": "Aggregate"
    },
    {
      "parameters": {
        "jsCode": "function parseMaybeJson(value) {\n  if (typeof value !== 'string') return null;\n  try { return JSON.parse(value); } catch { return null; }\n}\n\nfunction pickSource(payload) {\n  if (!payload || typeof payload !== 'object') return {};\n  if (payload.output && typeof payload.output === 'object') {\n    if (payload.output.output && typeof payload.output.output === 'object') return payload.output.output;\n    return payload.output;\n  }\n  const parsedOutput = parseMaybeJson(payload.output);\n  if (parsedOutput && typeof parsedOutput === 'object') return parsedOutput;\n  if (payload.data && typeof payload.data === 'object') return payload.data;\n  return payload;\n}\n\nfunction normalizeMemories(raw) {\n  const items = Array.isArray(raw) ? raw : [];\n  const out = [];\n\n  for (const item of items) {\n    if (item && typeof item === 'object' && typeof item.memory_text === 'string' && item.memory_text.trim()) {\n      out.push({\n        memory_text: item.memory_text.trim(),\n        memory_type: 'life_context',\n      });\n      continue;\n    }\n\n    if (typeof item === 'string') {\n      const trimmed = item.trim();\n      if (!trimmed) continue;\n      if (trimmed.toLowerCase().startsWith('memory_type')) continue;\n      if (trimmed.toLowerCase() === 'life_context') continue;\n      out.push({ memory_text: trimmed, memory_type: 'life_context' });\n      continue;\n    }\n  }\n\n  if (out.length === 0) {\n    return [];\n  }\n\n  return [out[0]];\n}\n\nconst source = pickSource($json);\nconst unwrapped =\n  source && typeof source === 'object' && source.output && typeof source.output === 'object'\n    ? source.output\n    : source;\n\nreturn [{\n  json: {\n    branch: 'memory',\n    model: 'gpt-4o-mini',\n    extracted_memories: normalizeMemories(unwrapped.extracted_memories)\n  }\n}];"
      },
